# ==============================
# 后端环境变量配置
# 复制本文件为 .env 并填入真实值
# 注意：.env 文件不要提交到 Git！
# ==============================

# 服务端口（本地开发用 3001，Docker 内用 3000）
PORT=3001

# 运行环境：development | production
NODE_ENV=development

# MySQL 数据库连接
DB_HOST=localhost
DB_PORT=3306
DB_USER=todouser
DB_PASSWORD=your_db_password_here
DB_NAME=todolist

# JWT 密钥（随机字符串，越长越安全）
JWT_SECRET=your_jwt_secret_here_change_this_in_production
